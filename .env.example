# Environment variable template for Bitcoin Prediction App
# Copy this to .env and fill in your real credentials

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key

# Dashboard → Project Settings → Database → Connection pooler (Transaction mode)
SUPABASE_DB_URL=postgresql://postgres.your-project-id:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── OpenRouter AI ─────────────────────────────────────────────────────────────
# Get your free API key at: https://openrouter.ai/keys
# Free tier includes: google/gemini-flash-1.5
OPENROUTER_API_KEY=your-openrouter-api-key

# ── FastAPI Server ────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=True
ENV=development
